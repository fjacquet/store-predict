# StorePredict — copy this file to .env and fill in your values
# .env is gitignored; .env.example is tracked

# Required
STORAGE_SECRET=change-me-in-production

# LLM Classification Fallback (optional)
# Uncomment and set LLM_API_KEY to enable AI classification of unknown VMs
# Default provider: OpenRouter with Mistral Small 3.1 (free tier available)
#
# LLM_ENABLED=true
# LLM_API_KEY=sk-or-v1-...          # OpenRouter key from https://openrouter.ai
# LLM_MODEL=mistralai/mistral-small-3.1-24b-instruct
# LLM_API_BASE=https://openrouter.ai/api/v1
#
# Free tier (rate limited, good for occasional use):
# LLM_MODEL=mistralai/mistral-small-3.1-24b-instruct:free
#
# Local Ollama (no API key needed):
# LLM_MODEL=ollama/gemma4:e4b           # any NON-thinking instruct model
# LLM_API_BASE=http://localhost:11434   # use host.docker.internal in Docker
# LLM_MAX_CONCURRENT=1                  # Ollama is single-threaded
# IMPORTANT: do NOT use a reasoning/"thinking" model (e.g. *-thinking). It emits
# <think>...</think> chain-of-thought instead of the terse "Category|KEYWORD"
# the classifier parses, so every VM comes back unclassified.
